# Copy what you need into the per-package env files noted below. Local defaults are
# baked into the code, so for a vanilla local run you only need the Convex admin key.

# --- Convex CLI (codegen / dev / deploy) → packages/backend/.env.local ---
# After `docker compose up -d`, run `bun run convex:admin-key` and paste the result.
CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=

# --- Web (Vite) → apps/web/.env (optional; code defaults to localhost:3210) ---
VITE_CONVEX_URL=http://127.0.0.1:3210

# --- Worker → shell or apps/workers/.env (all optional; code defaults shown) ---
CONVEX_URL=http://127.0.0.1:3210
RESTATE_INGRESS_URL=http://127.0.0.1:8080
RESTATE_ADMIN_URL=http://127.0.0.1:9070
RESTATE_SERVICE_URL=http://host.docker.internal:9080
# Tailscale: without TS_AUTHKEY the worker falls back to its LAN address.
# TS_AUTHKEY=tskey-auth-...
# WORKER_NAME=worker-1

		"@restatedev/restate-sdk-clients": "^1.15.0",
		"@t3-oss/env-core": "^0.13.11",
		"convex": "^1.40.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/node": "^22.10.2",
		"typescript": "^6.0.2"
	}

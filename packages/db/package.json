{
	"name": "@miku/db",
	"private": true,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"check": "tsc --noEmit",
		"lint": "biome lint --config-path ../../biome.json .",
		"format": "biome format --config-path ../../biome.json .",
		"migrate": "bun run migration:up",
		"migration:create": "bun ./node_modules/@mikro-orm/cli/cli.js migration:create",
		"migration:up": "bun ./node_modules/@mikro-orm/cli/cli.js migration:up",
		"migration:down": "bun ./node_modules/@mikro-orm/cli/cli.js migration:down",
		"migration:list": "bun ./node_modules/@mikro-orm/cli/cli.js migration:list"
	},
	"mikro-orm": {
		"useTsNode": false,
		"configPaths": ["./src/mikro-orm.config.ts", "./dist/mikro-orm.config.js"]
	},
	"dependencies": {
		"@mikro-orm/core": "^6.6.5",
		"@mikro-orm/migrations": "^6.6.5",
		"@mikro-orm/postgresql": "^6.6.5"
	},
	"devDependencies": {
		"@mikro-orm/cli": "^6.6.5",
		"@types/node": "^25.9.3",
		"typescript": "^6.0.2"
	}
}

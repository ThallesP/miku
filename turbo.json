{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"//#docker:up": {
			"cache": false
		},
		"@miku/db#migrate": {
			"cache": false,
			"dependsOn": ["//#docker:up"]
		},
		"dev": {
			"cache": false,
			"persistent": true,
			"dependsOn": ["^build", "@miku/db#migrate"]
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".output/**", "dist/**"]
		},
		"check": {
			"dependsOn": ["^build"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"format": {
			"cache": false
		}
	}
}

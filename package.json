{
	"name": "simple-turbo-tanstack-convex",
	"private": true,
	"type": "module",
	"workspaces": [
		"apps/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check": "biome check . && turbo check",
		"lint": "turbo lint",
		"format": "biome format --write .",
		"convex:dev": "bun --cwd apps/web convex dev"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"turbo": "latest"
	},
	"packageManager": "bun@1.3.8"
}

{
	"name": "miku",
	"private": true,
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "docker compose up -d --wait && turbo dev",
		"docker:up": "docker compose up -d --wait",
		"docker:down": "docker compose down",
		"convex:admin-key": "docker compose exec convex-backend ./generate_admin_key.sh",
		"codegen": "turbo run codegen --filter=@miku/backend",
		"build": "turbo build",
		"check": "biome check . && turbo check",
		"lint": "turbo lint",
		"format": "biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"turbo": "latest"
	},
	"packageManager": "bun@1.3.8"
}

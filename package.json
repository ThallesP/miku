{
	"name": "miku",
	"private": true,
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"docker:up": "docker compose up -d --wait",
		"build": "turbo build",
		"check": "biome check . && turbo check",
		"lint": "turbo lint",
		"format": "biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"turbo": "latest"
	},
	"packageManager": "bun@1.3.8"
}
